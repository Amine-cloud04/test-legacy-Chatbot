# Primary workflow (company PC + browser SSO):
# 1. Sync/download the SharePoint library to a local OneDrive folder
# 2. ./sync_from_folder.sh "/path/to/that/folder" --reset
# 3. ./run_review.sh   (uses .env.review — no SharePoint credentials)
#
# Optional fallback: password-based SharePoint API ingest (often blocked by MFA).
# SHAREPOINT_URL=https://contoso.sharepoint.com/sites/rd
# SHAREPOINT_USERNAME=user@contoso.com
# SHAREPOINT_PASSWORD=change-me
# SHAREPOINT_LIBRARY=Documents

LOCAL_DOCS_PATH=./sample_docs
DB_PATH=./data/knowledge_base.db
INDEX_PATH=./data/bm25_index.pkl
VECTOR_INDEX_PATH=./data/faiss.index
SYNC_MANIFEST_PATH=./data/sync_manifest.json
EMBEDDING_MODEL_PATH=
EMBEDDING_MODEL_NAME=sentence-transformers/paraphrase-multilingual-mpnet-base-v2
LOCAL_LLM_PATH=
LOCAL_LLM_SERVICE_URL=http://127.0.0.1:11434
LOCAL_LLM_SERVICE_MODEL=llama3.2:3b
LOCAL_LLM_MAX_NEW_TOKENS=320
LOCAL_LLM_CONTEXT_CHARS=6000
LOCAL_LLM_TIMEOUT=20
MAX_CHUNK_SIZE=640
CHUNK_OVERLAP=100
TOP_K=20
RERANK_TOP_K=5
USE_VECTOR_SEARCH=false
TECH_TERMS=radar,avionics,FPGA,UAV,IMU,GNSS,lidar,computer vision,embedded,navigation,sensor fusion
